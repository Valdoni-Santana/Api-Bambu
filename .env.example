# Credenciais Bambu Lab (use token OU usuário/senha; 2FA exige CLI na primeira vez)
BAMBU_USERNAME=
BAMBU_PASSWORD=
BAMBU_TOKEN=
BAMBU_UID=
BAMBU_REGION=global
# Caminho opcional para arquivo JSON do token (ex.: /root/.bambu_token no Docker)
BAMBU_TOKEN_FILE=

# Proteção da API NerdGeek (Bearer). Se vazio, a API fica aberta (apenas dev).
API_TOKEN=

DATABASE_URL=sqlite:///./storage/bambu_bridge.db
SNAPSHOT_DIR=./storage/snapshots
SNAPSHOT_INTERVAL_SECONDS=60
POLL_INTERVAL_SECONDS=120
MQTT_STALE_SECONDS=90
HISTORY_MAX_PER_PRINTER=100
HISTORY_SNAPSHOT_INTERVAL_SECONDS=60

LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8010

CAMERA_TIMEOUT_SECONDS=15
# JSON: {"01P00A123456789":"192.168.1.50"} — necessário para snapshot A1/P1 na LAN se não houver URL cloud
BAMBU_PRINTER_HOST_MAP=
